<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Restrict restore to the official NuGet feed for a reproducible, auditable supply chain. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
